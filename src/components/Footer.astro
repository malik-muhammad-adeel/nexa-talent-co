---
import LogoImage from './LogoImage.astro';

const quickLinks = [
  { href: '/about', label: 'About' },
  { href: '/services', label: 'Services' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/how-we-work', label: 'How We Work' },
  { href: '/contact', label: 'Contact' },
];

const socialLinks = [
  { href: 'https://www.instagram.com/nexa.talent.co/', label: 'Instagram' },
  { href: 'https://www.facebook.com/share/1CkKMNUT7h/', label: 'Facebook' },
  { href: 'https://x.com/NexaTalentCo', label: 'Twitter/X' },
  { href: 'https://www.threads.com/@nexa.talent.co', label: 'Threads' },
];
---

<footer class="site-footer">
  <div class="footer-grid" data-reveal-stagger>
    <div class="footer-brand-block">
      <div class="footer-logo-wrap">
        <div class="footer-logo">
          <LogoImage width={52} height={52} />
        </div>
        <div class="footer-wordmark">NEXA TALENT CO.</div>
      </div>
      <p class="footer-tagline">We run the backend, you run the content.</p>
      <p class="footer-desc">
        Operations partner for creators and coaches — we handle sales, funnels, email, and backend ops in exchange for a revenue share.
      </p>
    </div>

    <div class="footer-col">
      <h4>Quick links</h4>
      <ul class="footer-links">
        {quickLinks.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="footer-col">
      <h4>Contact</h4>
      <p class="footer-contact-item">
        <a href="mailto:nexa.talent.co@gmail.com">nexa.talent.co@gmail.com</a>
      </p>
      <p class="footer-contact-item">
        Prefer DMs? Reach us on <a href="https://www.instagram.com/nexa.talent.co/" target="_blank" rel="noopener noreferrer">Instagram</a>.
      </p>
    </div>

    <div class="footer-col">
      <h4>Social</h4>
      <div class="social-links">
        {socialLinks.map((link) => (
          <a href={link.href} class="social-link" target="_blank" rel="noopener noreferrer">
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <span>© {new Date().getFullYear()} Nexa Talent Co.</span>
    <span>nexatalent.online</span>
  </div>
</footer>
