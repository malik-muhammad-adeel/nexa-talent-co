---
import ParticleField from './ParticleField.astro';

interface Props {
  eyebrow: string;
  heading: string;
  subtext: string;
}

const { eyebrow, heading, subtext } = Astro.props;
---

<header class="page-header">
  <ParticleField />
  <div class="header-glow"></div>
  <div class="section-inner">
    <div class="eyebrow">{eyebrow}</div>
    <h1>{heading}</h1>
    <p class="lead">{subtext}</p>
  </div>
</header>
