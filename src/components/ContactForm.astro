<div class="contact-form">
  <form>
    <div class="form-group">
      <label for="name">Name</label>
      <input type="text" id="name" name="name" required autocomplete="name" />
    </div>
    <div class="form-group">
      <label for="email">Email</label>
      <input type="email" id="email" name="email" required autocomplete="email" />
    </div>
    <div class="form-group">
      <label for="instagram">Instagram handle (optional)</label>
      <input type="text" id="instagram" name="instagram" placeholder="@yourhandle" autocomplete="off" />
    </div>
    <div class="form-group">
      <label for="message">Message</label>
      <textarea id="message" name="message" required placeholder="Tell us about your audience and offer..."></textarea>
    </div>
    <button type="submit" class="btn-primary">Send message</button>
  </form>
</div>
