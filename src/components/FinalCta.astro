---
interface Props {
  eyebrow?: string;
  heading: string;
  subtext: string;
  ctaText: string;
  ctaHref: string;
}

const { eyebrow = "Let's talk", heading, subtext, ctaText, ctaHref } = Astro.props;
---

<section class="final-cta">
  <div class="section-inner">
    <div data-reveal>
      <div class="section-eyebrow eyebrow center">{eyebrow}</div>
      <h2 set:html={heading} />
      <p>{subtext}</p>
      <a href={ctaHref} class="btn-primary">{ctaText}</a>
    </div>
  </div>
</section>
