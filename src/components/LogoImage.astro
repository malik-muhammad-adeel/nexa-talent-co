---
import { Image } from 'astro:assets';
import logo from '../assets/logo-nt.png';

interface Props {
  width: number;
  height: number;
  alt?: string;
  class?: string;
  loading?: 'lazy' | 'eager';
}

const {
  width,
  height,
  alt = 'Nexa Talent Co.',
  class: className,
  loading = 'lazy',
} = Astro.props;
---

<Image
  src={logo}
  width={width}
  height={height}
  alt={alt}
  class={className}
  loading={loading}
  decoding="async"
  formats={['webp', 'png']}
/>
